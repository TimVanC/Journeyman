      "key": "unique id: TRICODE_startyear",
      "primary": "main jersey body color (road jersey base)",
      "secondary": "secondary/accent color",
      "trim": "trim/outline color",
      "eraStyle": "silhouette hint for renderer: classic (short/tight 70s-80s), nineties (looser, bold trim), baggy (2000s), modern (2010s+ minimal)",
      "confidence": "high | medium | low"
    },
    "relocations": "Franchises keyed by MODERN tricode. Historical identities (SEA, NJN, VAN, NOH, KC Kings, San Diego Clippers, Washington Bullets, Charlotte original Hornets) are separate era entries under the modern franchise with a 'identity' label so the renderer can note era city if you ever want it."
