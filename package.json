    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.6",
    "@vercel/analytics": "^2.0.1",
    "posthog-js": "^1.406.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.4",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.4",
    "typescript": "~5.8.3",
    "vite": "^6.3.0"
  }
